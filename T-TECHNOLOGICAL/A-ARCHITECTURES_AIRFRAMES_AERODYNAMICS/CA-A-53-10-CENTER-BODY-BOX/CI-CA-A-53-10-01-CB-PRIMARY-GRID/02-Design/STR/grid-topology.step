ISO-10303-21;
HEADER;
/*
********************************************************************************
* STEP AP214 - ISO 10303-21                                                    *
* Enhanced 3D Model - Center Body Structural Grid                              *
* File Version: 5.0 (Robust)                                                   *
* Enhancements: Applied expert patches for syntax errors. Refactored to a      *
* robust shell-based surface model with improved color definitions for maximum *
* compatibility, per CAD Genius review.                                        *
********************************************************************************
*/
FILE_DESCRIPTION(
('AQUA H2-BWB-Q100 Center Body Box Primary Grid - Robust Surface Model V5',
'Version 5.0 - Corrected and refactored surface model using OPEN_SHELL and SHELL_BASED_SURFACE_MODEL structure.'),
'2;1');
FILE_NAME(
'grid-topology-v5-robust.step',
'2025-08-30T02:54:00+02:00',
('AQUA Requirements System','Structural Design & Analysis Team'),
('Aerospace Design Division','Advanced Projects Group'),
'OpenCASCADE 7.7.0',
'AQUA-STEP-Generator-v5.0',
'');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 1 1 1 1 }'));
